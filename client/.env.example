# Client Server Configuration
PORT=3000

# URL of the API server (used by the proxy middleware to resolve subdomains)
API_SERVER_URL=http://localhost:9000

# S3 base path where project build outputs are stored
S3_OUTPUT_BASE=https://s3.ap-south-1.amazonaws.com/nexus-cloud-v2.0/__outputs

# Firebase configuration (required for authentication)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
